# Nightly supervisor environment — copy to `nightly.env` and fill in.
#   cp supervisor/nightly.env.example supervisor/nightly.env
#   $EDITOR supervisor/nightly.env
# `nightly.env` is gitignored. Both the SMTP test and launchd source it.

# ── Pipeline ──────────────────────────────────────────────────────────────
export PODCAST_OUTPUT_DIR="$HOME/source/personal/nanoclaw/groups/telegram_main/MoneyPrinterV2FUJIWARA/output/podcasts"
export OLLAMA_URL="http://localhost:11434/api/generate"
export FACTFULL_LLM_BACKEND="ollama"
export FACTFULL_OLLAMA_MODEL="gemma4:e4b"
export HOMUPE_DIR="$HOME/source/personal/homupe"

# ── Notification (Telegram push, reuses nanoclaw's bot) ─────────────────────
# Copy TELEGRAM_BOT_TOKEN from nanoclaw/.env (do NOT commit it).
# TELEGRAM_CHAT_ID is your DM with @Nanoikm_bot (from nanoclaw registered_groups).
export TELEGRAM_BOT_TOKEN="paste-from-nanoclaw/.env"
export TELEGRAM_CHAT_ID="8552913958"
